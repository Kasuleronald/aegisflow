# --- Postgres admin connection (must have CREATE DATABASE privilege) ---
# This is the connection used ONLY to create new per-company databases.
PG_ADMIN_HOST=localhost
PG_ADMIN_PORT=5432
PG_ADMIN_USER=postgres
PG_ADMIN_PASSWORD=changeme
# "Maintenance" db to connect to when issuing CREATE DATABASE (usually 'postgres')
PG_ADMIN_DB=postgres

# --- Platform (master) database ---
# Holds: companies, platform_admins, directory (email -> company)
PLATFORM_DB_NAME=aegisflow_platform

# --- Shared credentials new per-company databases will use ---
# (In production, consider per-tenant DB users/passwords for stronger isolation.)
PG_APP_USER=postgres
PG_APP_PASSWORD=changeme
PG_APP_HOST=localhost
PG_APP_PORT=5432

# --- Auth ---
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=8h

# --- Server ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Bootstrap platform admin (used once by seedPlatformAdmin.js) ---
BOOTSTRAP_ADMIN_EMAIL=you@aegisflow.com
BOOTSTRAP_ADMIN_PASSWORD=changeme123
BOOTSTRAP_ADMIN_NAME=Platform Admin
