{
  "name": "aegisflow",
  "version": "1.0.0",
  "private": true,
  "description": "AegisFlow Multi-Tenant ERP (React + Vite + Express)",
  "type": "module",
  "main": "src/index.js",
   "scripts": {
    "client": "vite",
    "server": "node --watch src/index.js",
    "dev": "vite",
    "start": "node src/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "migrate:platform": "node src/db/migratePlatform.js",
    "seed:admin": "node src/db/seedPlatformAdmin.js",
    "autosync": "git add . && git commit -m 'autosync' && git push",
    "deploy": "npm run build && npm run migrate:platform"
  },

  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.22.0",
    "papaparse": "^5.5.4",
    "pg": "^8.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.8.2",
    "recharts": "^3.9.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "vite": "^7.3.6"
  }
}
